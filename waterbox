#!/usr/bin/env bash

# simple sandbox for running CLI AI agents

set -e

WATERBOX_VERSION="1.6"

# Absolute path to this script, recorded so the shell-completion snippet can fall
# back to it when 'waterbox' isn't on $PATH (e.g. run by ./waterbox, or moved).
SELF_PATH="$(readlink -f "${BASH_SOURCE[0]:-$0}" 2>/dev/null || echo "$0")"

# --- Configuration ---
JAIL_ROOT="$HOME/.waterbox/root"
CONFIG_DIR="$HOME/.waterbox"
SHARE_LIST="$CONFIG_DIR/shared_paths"
GUI_ENV_FILE="$CONFIG_DIR/gui_env"       # export VAR="val" lines; helper copies into the rootfs
GUI_BINDS_FILE="$CONFIG_DIR/gui_binds"   # --bind spec lines the helper validates at boot
USER_NAME="water"               # user inside the container (uid 1000 == host user)
RUN_USER="$(id -un)"            # the host user invoking this script
MACHINE_NAME="waterbox"         # external name: systemd unit, machinectl, ve-* iface
INSIDE_HOSTNAME="box"           # hostname shown inside the container
TMUX_SESSION="box"              # tmux session that wraps the interactive shell
CONTAINER_WORKSPACE="/home/$USER_NAME/workspace"

# Root helper (req: safe privilege model). All privileged RUNTIME ops go through
# this root-owned, uid-1000-immutable binary so the sudoers rule can be NOPASSWD
# for THIS one file only (fixed verbs, no argument-injection path). bootstrap/reset
# stay on interactive sudo (inherently broad; you're present for them).
HELPER_DIR="/usr/local/lib/waterbox"
HELPER_PATH="$HELPER_DIR/waterbox-helper"
HELPER_SUDOERS="/etc/sudoers.d/waterbox-helper"

# --- Network parameters ---
HOST_IP="10.20.30.1"
CONTAINER_IP="10.20.30.2"
NET_CIDR="24"
HOST_ALIAS="host"               # name resolved to $HOST_IP inside the container
VE_IFACE="ve-$MACHINE_NAME"     # systemd-nspawn names the host side ve-<machine>

# If true, the container (10.20.30.0/24) is allowed to reach ANY port the host
# listens on. Combined with the DNAT rule below, this lets the container hit
# host loopback services (MCP servers, dev servers, etc.) as `host:PORT` even
# when the host has a restrictive INPUT policy (ufw, firewalld, etc.).
ALLOW_CONTAINER_TO_HOST_PORTS=true

# DNS servers used inside the container. A VPN client inside is free to replace
# /etc/resolv.conf at runtime.
DNS_SERVERS=("8.8.8.8" "1.1.1.1")

# --- Arch bootstrap image (req 6: no host pacstrap, works on any distro) ------
# We fetch the official signed Arch bootstrap tarball and install packages
# *inside* it with the container's own pacman, so the host only needs
# systemd-nspawn + iptables + curl + gpg/pacman-key + zstd/tar (all on Mint via
# apt). The big tarball comes from a fast geo mirror, but the signature comes
# from archlinux.org (an independent canonical origin) and is verified against a
# pinned key — so a malicious mirror can't slip in a forged image.
ARCH_MIRROR="https://geo.mirror.pkgbuild.com/iso/latest"
ARCH_SIG_ORIGIN="https://archlinux.org/iso/latest"
ARCH_BOOTSTRAP_TARBALL="archlinux-bootstrap-x86_64.tar.zst"
# Verified live (2026-06): the bootstrap image is signed by Pierre Schmitz.
# Update from https://archlinux.org/ (master keys) over HTTPS if Arch rotates it.
ARCH_BOOTSTRAP_KEY="3E80CA1A8B89F69CBA57D98A76A5EF9054449A5C"

PKGS=(
    base base-devel bash git nodejs npm sudo coreutils
    iproute2 iputils dbus
    zsh powerline powerline-fonts grml-zsh-config
    zsh-autosuggestions zsh-completions
    zsh-history-substring-search zsh-syntax-highlighting
    ripgrep tmux bind vim less
    openssh nano openbsd-netcat curl
)

# GUI: display forwarding. Default "auto" = ON when the host is Wayland (clients are
# well-isolated), OFF on X11 (any X client can keylog/screenshot the whole session).
# Force with --gui / --no-gui, or WATERBOX_GUI=1/0. GPU (/dev/dri) is shared, not
# exclusive, so it's bound by default; --no-gpu off.
WATERBOX_GUI="${WATERBOX_GUI:-auto}"
WATERBOX_NO_GPU="${WATERBOX_NO_GPU:-0}"

mkdir -p "$CONFIG_DIR"
touch "$SHARE_LIST"

# --- Logging ---
log_info()    { echo -e "\e[34m[INFO]\e[0m $1"; }
log_success() { echo -e "\e[32m[ OK ]\e[0m $1"; }
log_warn()    { echo -e "\e[33m[WARN]\e[0m $1"; }
log_error()   { echo -e "\e[31m[ERR ]\e[0m $1"; exit 1; }

# Ctrl-C anywhere: restore the terminal cursor (menus hide it) and exit cleanly with
# no error code or stack — the user asked that interrupting a menu not look like a
# crash. Menus also offer an in-list 'quit' + 'q' to back out without leaving.
_on_interrupt() { printf '\e[?25h\n' > /dev/tty 2>/dev/null || true; exit 0; }
trap _on_interrupt INT

